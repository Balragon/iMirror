<ui:FluentWindow x:Class="MacMirrorReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="iMirror"
        Width="1180"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        Foreground="{DynamicResource TextBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        StateChanged="Window_StateChanged"
        KeyDown="Window_KeyDown"
        PreviewKeyDown="Window_KeyDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MacMirrorReceiver/SharedResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- MainWindow-only styles ──────────────────────────────────── -->
            <Style x:Key="ComboStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="Background" Value="#3A1717" />
                <Setter Property="BorderBrush" Value="#7A3030" />
                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            </Style>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="MainTitleBar"
                     Title="iMirror"
                     Grid.Row="0" />

        <Grid Grid.Row="1"
              Background="Transparent">
            <Grid x:Name="VideoStage"
                  Background="Transparent"
                  ClipToBounds="True"
                  MouseLeftButtonDown="VideoStage_MouseLeftButtonDown"
                  PreviewMouseLeftButtonDown="VideoStage_MouseLeftButtonDown">
            <Image x:Name="VideoImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Canvas x:Name="RemoteCursorLayer"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <Grid x:Name="RemoteCursor"
                      Width="22"
                      Height="28">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="RemoteCursorScale"
                                        ScaleX="0.45"
                                        ScaleY="0.45" />
                    </Grid.RenderTransform>
                    <Path Data="M 1 1 L 1 21 L 6.5 15.4 L 10.2 24.2 L 14.2 22.5 L 10.4 13.9 L 18.8 13.9 Z"
                          Fill="#FFFFFF"
                          Stroke="#000000"
                          StrokeThickness="1.5"
                          StrokeLineJoin="Round" />
                </Grid>
            </Canvas>

            <Grid x:Name="EmptyStatePanel"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="520"
                            Margin="40">
                    <Grid Width="150"
                          Height="192"
                          HorizontalAlignment="Center">
                        <Border CornerRadius="34"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                Opacity="0.94">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#42FFFFFF"
                                                  Offset="0" />
                                    <GradientStop Color="#24FFFFFF"
                                                  Offset="0.54" />
                                    <GradientStop Color="#0EFFFFFF"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border Margin="9"
                                CornerRadius="27"
                                BorderBrush="#2BFFFFFF"
                                BorderThickness="1"
                                Background="#2213181F" />
                        <Border Margin="24,46,24,54"
                                CornerRadius="16"
                                BorderBrush="#20FFFFFF"
                                BorderThickness="1"
                                Background="#1AFFFFFF" />
                        <Border Width="42"
                                Height="4"
                                CornerRadius="2"
                                Background="#9AFFFFFF"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,17,0,0" />
                        <Border Width="70"
                                Height="3"
                                CornerRadius="1.5"
                                Background="#66FFFFFF"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,17" />
                    </Grid>

                    <TextBlock x:Name="EmptyStateTextBlock"
                               Text="Ready to mirror"
                               AutomationProperties.LiveSetting="Polite"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#F7F8FA"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,30,0,0" />
                    <StackPanel x:Name="DiagStatusPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Opacity="0.94"
                                Margin="0,14,0,0">
                        <Ellipse x:Name="DiagStatusDot"
                                 Width="8"
                                 Height="8"
                                 Fill="{StaticResource WarningBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="DiagStatusText"
                                   Text="Checking&#x2026;"
                                   Foreground="#D6D8DE"
                                   FontSize="13"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ui:Button x:Name="RecheckDiagLink"
                               Content="Re-check"
                               Appearance="Transparent"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Padding="8,0"
                               MinHeight="30"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"
                               AutomationProperties.Name="Re-check readiness"
                               Click="RecheckDiagLink_Click" />
                    <ui:Button x:Name="FirewallAllowInlineButton"
                               Content="Allow in Firewall"
                               Appearance="Secondary"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Padding="12,0"
                               MinHeight="30"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Visibility="Collapsed"
                               AutomationProperties.Name="Allow iMirror in Windows Firewall"
                               Click="FirewallAllowButton_Click" />
                    <TextBlock x:Name="EmptyStateDetailTextBlock"
                               Text="Open Control Center, tap Screen Mirroring, then choose iMirror."
                               AutomationProperties.LiveSetting="Polite"
                               Foreground="#C8CAD0"
                               FontSize="15"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="23"
                               Margin="0,14,0,0" />
                </StackPanel>
            </Grid>
        </Grid>

        <Border x:Name="ReceiverCardBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10,0,0"
                Padding="14,8"
                Background="#E6FFFFFF"
                BorderBrush="#66FFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Panel.ZIndex="20">
            <StackPanel Orientation="Horizontal"
                        AutomationProperties.LiveSetting="Polite">
                <Ellipse x:Name="SidebarStatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource WarningBrush}"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderSubtitleTextBlock"
                           Text="Waiting on this network"
                           Foreground="#1F2329"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center" />
                <ui:Button x:Name="FirewallAllowButton"
                           Content="Allow"
                           Appearance="Primary"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Padding="10,0"
                           MinHeight="26"
                           Margin="10,0,0,0"
                           Visibility="Collapsed"
                           AutomationProperties.Name="Allow iMirror in Windows Firewall"
                           Click="FirewallAllowButton_Click" />

                <StackPanel Width="0"
                            Height="0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="ReceiverCardTitleTextBlock"
                               Text="Ready to receive" />
                    <Border x:Name="ReceiverStateBadge"
                            Background="{StaticResource AccentBrush}">
                        <TextBlock x:Name="ReceiverStateBadgeTextBlock"
                                   Text="READY" />
                    </Border>
                    <TextBlock x:Name="ReceiverStatusTextBlock"
                               Text="Waiting for iPhone or iPad..." />
                    <TextBlock x:Name="AirPlayProbeTextBlock"
                               Text="AirPlay receiver not started." />
                    <Ellipse x:Name="EmptyStateStatusDot"
                             Width="8"
                             Height="8"
                             Fill="{StaticResource WarningBrush}" />
                    <TextBlock x:Name="EmptyStateStatusTextBlock"
                               Text="Waiting for iPhone or iPad..." />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="UpdateNoticeBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Padding="14,9"
                MaxWidth="620"
                Background="#EE1F2329"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Panel.ZIndex="21"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UpdateNoticeTextBlock"
                           Text="A new iMirror update is available."
                           Foreground="#F7F8FA"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <ui:Button x:Name="UpdateNoticeInstallButton"
                           Grid.Column="1"
                           Content="Update"
                           Appearance="Primary"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Padding="10,0"
                           MinHeight="28"
                           Click="UpdateNoticeInstallButton_Click" />
                <ui:Button x:Name="UpdateNoticeDismissButton"
                           Grid.Column="2"
                           Content="Later"
                           Appearance="Transparent"
                           Foreground="#D6D8DE"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Padding="10,0"
                           MinHeight="28"
                           Margin="4,0,0,0"
                           Click="UpdateNoticeDismissButton_Click" />
            </Grid>
        </Border>


        <Grid x:Name="LegacyBindingsHost"
              Width="0"
              Height="0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Visibility="Collapsed"
              IsHitTestVisible="False">
            <Border x:Name="ReadinessStripBorder"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="ReadinessStripHeaderText" />
                    <Button x:Name="ReadinessRecheckButton"
                            Content="Re-check"
                            Click="ReadinessRecheckButton_Click" />
                    <StackPanel x:Name="FfmpegCheckRow"
                                Visibility="Collapsed">
                        <TextBlock x:Name="FfmpegCheckText" />
                        <TextBlock x:Name="FfmpegCheckDetail"
                                   Visibility="Collapsed" />
                    </StackPanel>
                    <StackPanel x:Name="ListenersCheckRow"
                                Visibility="Collapsed">
                        <TextBlock x:Name="ListenersCheckText" />
                        <TextBlock x:Name="ListenersCheckDetail"
                                   Visibility="Collapsed" />
                        <Button x:Name="FirewallHelpButton"
                                Content="Allow in Firewall"
                                Click="FirewallHelpButton_Click" />
                    </StackPanel>
                    <StackPanel x:Name="NetworkCheckRow"
                                Visibility="Collapsed">
                        <TextBlock x:Name="NetworkCheckText" />
                        <TextBlock x:Name="NetworkCheckDetail"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="HowToMirrorCard"
                    Visibility="Collapsed" />

            <StackPanel>
                <ComboBox x:Name="DeviceComboBox"
                          DisplayMemberPath="DisplayName" />
                <TextBlock x:Name="DeviceSummaryTextBlock"
                           Text="No legacy sender found yet" />
                <TextBox x:Name="HostTextBox" />
                <TextBox x:Name="PortTextBox"
                         Text="55991" />
                <TextBox x:Name="PinTextBox"
                         MaxLength="6"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         KeyDown="PinTextBox_KeyDown" />
                <StackPanel x:Name="RenderModePanel"
                            Visibility="Collapsed">
                    <ComboBox x:Name="RenderModeComboBox"
                              SelectionChanged="RenderModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="Responsive" />
                        <ComboBoxItem Content="Native 4K" />
                    </ComboBox>
                    <TextBlock x:Name="RenderModeDetailTextBlock" />
                </StackPanel>
                <Button x:Name="ConnectButton"
                        Content="Connect Sender"
                        Click="ConnectButton_Click" />
                <Button x:Name="DisconnectButton"
                        Content="Stop"
                        IsEnabled="False"
                        Click="DisconnectButton_Click" />
                <Button x:Name="ReconnectButton"
                        Content="Retry"
                        IsEnabled="False"
                        Click="ReconnectButton_Click" />
                <Button x:Name="FullscreenButton"
                        Content="Fullscreen"
                        Click="FullscreenButton_Click" />
                <StackPanel x:Name="StatusSummaryPanel"
                            Visibility="Collapsed">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Waiting for iPhone or iPad..." />
                </StackPanel>
                <TextBlock x:Name="DiagnosticsTextBlock" />
            </StackPanel>

            <Border x:Name="CompactControlBar"
                    Visibility="Collapsed"
                    ToolTip="Disconnected.">
                <StackPanel>
                    <Button x:Name="CompactDisconnectButton"
                            Content="X"
                            Click="CompactDisconnectButton_Click" />
                    <Button x:Name="CompactReconnectButton"
                            Content="R"
                            IsEnabled="False"
                            Click="CompactReconnectButton_Click" />
                    <Button x:Name="CompactFullscreenButton"
                            Content="F"
                            Click="CompactFullscreenButton_Click" />
                    <TextBlock x:Name="CompactStatusTextBlock"
                               Text="Disconnected." />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
    </Grid>
</ui:FluentWindow>
