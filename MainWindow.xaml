<Window x:Class="MacMirrorReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iMirror"
        Width="1180"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#000000"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        Foreground="#1D1D1F"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        KeyDown="Window_KeyDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FBFBFD" />
        <SolidColorBrush x:Key="TextBrush" Color="#1D1D1F" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6E6E73" />
        <SolidColorBrush x:Key="LineBrush" Color="#D2D2D7" />
        <SolidColorBrush x:Key="FieldBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#007AFF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF3B30" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#34C759" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FF9F0A" />

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFF4F3" />
            <Setter Property="BorderBrush" Value="#FFD0CC" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style x:Key="CompactIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CompactDangerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="#000000">
        <Grid x:Name="VideoStage"
              Background="#000000"
              MouseLeftButtonDown="VideoStage_MouseLeftButtonDown">
            <Image x:Name="VideoImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Canvas x:Name="RemoteCursorLayer"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <Grid x:Name="RemoteCursor"
                      Width="22"
                      Height="28">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="RemoteCursorScale"
                                        ScaleX="0.45"
                                        ScaleY="0.45" />
                    </Grid.RenderTransform>
                    <Path Data="M 1 1 L 1 21 L 6.5 15.4 L 10.2 24.2 L 14.2 22.5 L 10.4 13.9 L 18.8 13.9 Z"
                          Fill="#FFFFFF"
                          Stroke="#000000"
                          StrokeThickness="1.5"
                          StrokeLineJoin="Round" />
                </Grid>
            </Canvas>

            <Grid x:Name="EmptyStatePanel"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="480"
                            Margin="32">
                    <Grid Width="132"
                          Height="176"
                          HorizontalAlignment="Center">
                        <Border CornerRadius="30"
                                Background="#101014"
                                BorderBrush="#34343A"
                                BorderThickness="1.5" />
                        <Border Width="48"
                                Height="5"
                                CornerRadius="2.5"
                                Background="#303037"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,14,0,0" />
                        <TextBlock Text="iMirror"
                                   Foreground="#F5F5F7"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock x:Name="EmptyStateTextBlock"
                               Text="Ready to mirror"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#F5F5F7"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,28,0,0" />
                    <TextBlock x:Name="EmptyStateDetailTextBlock"
                               Text="Open Control Center, tap Screen Mirroring, then choose iMirror."
                               Foreground="#B9B9C0"
                               FontSize="15"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Grid>
        </Grid>

        <Border x:Name="ReceiverCardBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Padding="12,7"
                Background="#EEF5F5F7"
                BorderBrush="#88FFFFFF"
                BorderThickness="1"
                CornerRadius="14"
                Panel.ZIndex="20">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="SidebarStatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource WarningBrush}"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderSubtitleTextBlock"
                           Text="Waiting on this network"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center" />

                <StackPanel Width="0"
                            Height="0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="ReceiverCardTitleTextBlock"
                               Text="Ready to receive" />
                    <Border x:Name="ReceiverStateBadge"
                            Background="{StaticResource AccentBrush}">
                        <TextBlock x:Name="ReceiverStateBadgeTextBlock"
                                   Text="READY" />
                    </Border>
                    <TextBlock x:Name="ReceiverStatusTextBlock"
                               Text="Waiting for iPhone or iPad..." />
                    <TextBlock x:Name="AirPlayProbeTextBlock"
                               Text="AirPlay receiver not started." />
                    <Ellipse x:Name="EmptyStateStatusDot"
                             Width="8"
                             Height="8"
                             Fill="{StaticResource WarningBrush}" />
                    <TextBlock x:Name="EmptyStateStatusTextBlock"
                               Text="Waiting for iPhone or iPad..." />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,12,0"
                Padding="5"
                Background="#EEF5F5F7"
                BorderBrush="#88FFFFFF"
                BorderThickness="1"
                CornerRadius="14"
                Panel.ZIndex="20">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="SettingsButton"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Content="&#xE713;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="13"
                        ToolTip="Settings"
                        Click="SettingsButton_Click"
                        Style="{StaticResource CompactIconButtonStyle}" />
                <Button Width="32"
                        Height="32"
                        Margin="6,0,0,0"
                        Padding="0"
                        Content="&#xE921;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        ToolTip="Minimize"
                        Click="MinimizeWindowButton_Click"
                        Style="{StaticResource CompactIconButtonStyle}" />
                <Button Width="32"
                        Height="32"
                        Margin="6,0,0,0"
                        Padding="0"
                        Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        ToolTip="Close"
                        Click="CloseWindowButton_Click"
                        Style="{StaticResource CompactDangerIconButtonStyle}" />
            </StackPanel>
        </Border>

        <Grid x:Name="LegacyBindingsHost"
              Width="0"
              Height="0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Visibility="Collapsed"
              IsHitTestVisible="False">
            <Border x:Name="ReadinessStripBorder"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="ReadinessStripHeaderText" />
                    <Button x:Name="ReadinessRecheckButton"
                            Content="Re-check"
                            Click="ReadinessRecheckButton_Click" />
                    <StackPanel x:Name="FfmpegCheckRow"
                                Visibility="Collapsed">
                        <TextBlock x:Name="FfmpegCheckText" />
                        <TextBlock x:Name="FfmpegCheckDetail"
                                   Visibility="Collapsed" />
                    </StackPanel>
                    <StackPanel x:Name="ListenersCheckRow"
                                Visibility="Collapsed">
                        <TextBlock x:Name="ListenersCheckText" />
                        <TextBlock x:Name="ListenersCheckDetail"
                                   Visibility="Collapsed" />
                        <Button x:Name="FirewallHelpButton"
                                Content="Open Windows Firewall settings"
                                Click="FirewallHelpButton_Click" />
                    </StackPanel>
                    <StackPanel x:Name="NetworkCheckRow"
                                Visibility="Collapsed">
                        <TextBlock x:Name="NetworkCheckText" />
                        <TextBlock x:Name="NetworkCheckDetail"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="HowToMirrorCard"
                    Visibility="Collapsed" />

            <StackPanel>
                <ComboBox x:Name="DeviceComboBox"
                          DisplayMemberPath="DisplayName" />
                <TextBlock x:Name="DeviceSummaryTextBlock"
                           Text="No legacy sender found yet" />
                <TextBox x:Name="HostTextBox" />
                <TextBox x:Name="PortTextBox"
                         Text="55991" />
                <TextBox x:Name="PinTextBox"
                         MaxLength="6"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         KeyDown="PinTextBox_KeyDown" />
                <StackPanel x:Name="RenderModePanel"
                            Visibility="Collapsed">
                    <ComboBox x:Name="RenderModeComboBox"
                              SelectionChanged="RenderModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="Responsive" />
                        <ComboBoxItem Content="Native 4K" />
                    </ComboBox>
                    <TextBlock x:Name="RenderModeDetailTextBlock" />
                </StackPanel>
                <Button x:Name="ConnectButton"
                        Content="Connect Sender"
                        Click="ConnectButton_Click" />
                <Button x:Name="DisconnectButton"
                        Content="Stop"
                        IsEnabled="False"
                        Click="DisconnectButton_Click" />
                <Button x:Name="ReconnectButton"
                        Content="Retry"
                        IsEnabled="False"
                        Click="ReconnectButton_Click" />
                <Button x:Name="FullscreenButton"
                        Content="Fullscreen"
                        Click="FullscreenButton_Click" />
                <StackPanel x:Name="StatusSummaryPanel"
                            Visibility="Collapsed">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Waiting for iPhone or iPad..." />
                </StackPanel>
                <TextBlock x:Name="DiagnosticsTextBlock" />
            </StackPanel>

            <Border x:Name="CompactControlBar"
                    Visibility="Collapsed"
                    ToolTip="Disconnected.">
                <StackPanel>
                    <Button x:Name="CompactDisconnectButton"
                            Content="X"
                            Click="CompactDisconnectButton_Click" />
                    <Button x:Name="CompactReconnectButton"
                            Content="R"
                            IsEnabled="False"
                            Click="CompactReconnectButton_Click" />
                    <Button x:Name="CompactFullscreenButton"
                            Content="F"
                            Click="CompactFullscreenButton_Click" />
                    <TextBlock x:Name="CompactStatusTextBlock"
                               Text="Disconnected." />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
