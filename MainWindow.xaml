<Window x:Class="MacMirrorReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iMirror"
        Width="1180"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        Foreground="#1D1D1F"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        KeyDown="Window_KeyDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FBFBFD" />
        <SolidColorBrush x:Key="TextBrush" Color="#1D1D1F" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6E6E73" />
        <SolidColorBrush x:Key="LineBrush" Color="#D2D2D7" />
        <SolidColorBrush x:Key="FieldBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#007AFF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF3B30" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#34C759" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FF9F0A" />

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFF4F3" />
            <Setter Property="BorderBrush" Value="#FFD0CC" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style x:Key="CompactIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CompactDangerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="SidebarPanel"
                Grid.Column="0"
                Padding="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#E5E5EA"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="iMirror" FontSize="20" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                            <Ellipse x:Name="SidebarStatusDot"
                                     Width="8"
                                     Height="8"
                                     Fill="{StaticResource WarningBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock x:Name="HeaderSubtitleTextBlock"
                                       Text="Waiting on this network"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="HidePanelButton"
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Content="&lt;"
                            ToolTip="Hide panel"
                            Click="HidePanelButton_Click"
                            Style="{StaticResource CompactIconButtonStyle}" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Background="#EEF7FF"
                                BorderBrush="#D6E9FF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Ready to receive"
                                           FontWeight="SemiBold"
                                           FontSize="15" />
                                <TextBlock x:Name="ReceiverStatusTextBlock"
                                           Text="Waiting for iPhone or iPad..."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0"
                                           LineHeight="18" />
                                <TextBlock x:Name="AirPlayProbeTextBlock"
                                           Text="AirPlay receiver not started."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           LineHeight="18" />
                            </StackPanel>
                        </Border>

                        <Border Background="#F6F6F8"
                                BorderBrush="#E5E5EA"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="How to mirror"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="18" Height="18" CornerRadius="9" Background="#DDEBFF">
                                        <TextBlock Text="1" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Open Control Center on your iPhone or iPad."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="18" Height="18" CornerRadius="9" Background="#DDEBFF">
                                        <TextBlock Text="2" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Tap Screen Mirroring and choose iMirror."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="18" Height="18" CornerRadius="9" Background="#DDEBFF">
                                        <TextBlock Text="3" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Keep both devices on the same Wi-Fi. The screen appears on the right."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#F6F6F8"
                                BorderBrush="#E5E5EA"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Quality mode"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <TextBlock x:Name="RenderModeSettingDetailTextBlock"
                                           Text="1080p AirPlay display for smooth mirroring."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0"
                                           LineHeight="18" />

                                <RadioButton x:Name="StableRenderModeRadioButton"
                                             GroupName="ReceiverRenderMode"
                                             Checked="RenderModeSettingRadioButton_Checked"
                                             Margin="0,12,0,0">
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="Stable (recommended)"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="1080p, smoother on more PCs."
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="QualityRenderModeRadioButton"
                                             GroupName="ReceiverRenderMode"
                                             Checked="RenderModeSettingRadioButton_Checked"
                                             Margin="0,10,0,0">
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="High quality"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Experimental high-res testing only."
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </RadioButton>

                                <TextBlock x:Name="RenderModeNoteTextBlock"
                                           Text="GPU mode is enabled when hardware decode is available."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           Margin="0,10,0,0"
                                           LineHeight="17" />

                                <TextBlock x:Name="RenderModeOverrideTextBlock"
                                           Text="IMIRROR_RENDER_MODE is overriding this setting."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           Margin="0,10,0,0"
                                           LineHeight="17" />

                                <Border x:Name="RenderModeRestartPanel"
                                        Background="#FFF8E8"
                                        BorderBrush="#FFE0A8"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,12,0,0"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Restart required. AirPlay connections will disconnect."
                                                   Foreground="#6B4A00"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   LineHeight="17" />
                                        <Button x:Name="RestartForRenderModeButton"
                                                Grid.Row="1"
                                                Content="Restart now"
                                                Click="RestartForRenderModeButton_Click"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="0,9,0,0" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Expander Header="Legacy sender (optional)"
                                  IsExpanded="False"
                                  Margin="0,0,0,0"
                                  Foreground="{StaticResource MutedTextBrush}">
                            <Border Background="#F5F5F7"
                                    BorderBrush="#E5E5EA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Discovered sender" Style="{StaticResource LabelTextStyle}" />
                                    <ComboBox x:Name="DeviceComboBox"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource ComboStyle}" />
                                    <TextBlock x:Name="DeviceSummaryTextBlock"
                                               Text="No legacy sender found yet"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="1,7,0,0" />

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="92" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Manual sender address" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox x:Name="HostTextBox"
                                                     Style="{StaticResource FieldTextBoxStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="Port" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox x:Name="PortTextBox"
                                                     Text="55991"
                                                     Style="{StaticResource FieldTextBoxStyle}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,12,0,0">
                                        <TextBlock Text="Sender PIN" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox x:Name="PinTextBox"
                                                 MaxLength="6"
                                                 FontSize="19"
                                                 FontWeight="SemiBold"
                                                 HorizontalContentAlignment="Center"
                                                 PreviewTextInput="PinTextBox_PreviewTextInput"
                                                 KeyDown="PinTextBox_KeyDown"
                                                 Style="{StaticResource FieldTextBoxStyle}" />
                                    </StackPanel>

                                    <StackPanel x:Name="RenderModePanel"
                                                Margin="0,12,0,0"
                                                Visibility="Collapsed">
                                        <TextBlock Text="Render" Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="RenderModeComboBox"
                                                  Style="{StaticResource ComboStyle}"
                                                  SelectionChanged="RenderModeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Auto" />
                                            <ComboBoxItem Content="Responsive" />
                                            <ComboBoxItem Content="Native 4K" />
                                        </ComboBox>
                                        <TextBlock x:Name="RenderModeDetailTextBlock"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="1,7,0,0" />
                                    </StackPanel>

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="ConnectButton"
                                                Content="Connect Sender"
                                                Click="ConnectButton_Click"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button x:Name="DisconnectButton"
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Content="Stop"
                                                IsEnabled="False"
                                                Click="DisconnectButton_Click"
                                                Style="{StaticResource DangerButtonStyle}" />
                                    </Grid>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="ReconnectButton"
                                                Content="Retry"
                                                IsEnabled="False"
                                                Click="ReconnectButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button x:Name="FullscreenButton"
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Content="Fullscreen"
                                                Click="FullscreenButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <TextBlock Text="Status" Style="{StaticResource LabelTextStyle}" Margin="0,18,0,7" />
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="Waiting for iPhone or iPad..."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}"
                                   LineHeight="20" />

                        <Expander Header="Diagnostics"
                                  IsExpanded="False"
                                  Margin="0,16,0,0"
                                  Foreground="{StaticResource MutedTextBrush}">
                            <Border Background="#F5F5F7"
                                    BorderBrush="#E5E5EA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,8,0,0">
                                <TextBlock x:Name="DiagnosticsTextBlock"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11"
                                           Foreground="#4B4B50"
                                           TextWrapping="Wrap" />
                            </Border>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="2"
                           Text="Local network only"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"
                           Margin="0,18,0,0" />
            </Grid>
        </Border>

        <Border x:Name="CompactControlBar"
                Grid.Column="0"
                Visibility="Collapsed"
                Padding="7"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#E5E5EA"
                BorderThickness="0,0,1,0"
                ToolTip="Disconnected.">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <Button x:Name="ShowPanelButton"
                            Content="&gt;"
                            ToolTip="Show panel"
                            Click="ShowPanelButton_Click"
                            Style="{StaticResource CompactIconButtonStyle}" />
                    <Button x:Name="CompactDisconnectButton"
                            Content="X"
                            Margin="0,8,0,0"
                            ToolTip="Disconnect"
                            Click="CompactDisconnectButton_Click"
                            Style="{StaticResource CompactDangerIconButtonStyle}" />
                    <Button x:Name="CompactReconnectButton"
                            Content="R"
                            Margin="0,8,0,0"
                            ToolTip="Reconnect"
                            IsEnabled="False"
                            Click="CompactReconnectButton_Click"
                            Style="{StaticResource CompactIconButtonStyle}" />
                </StackPanel>
                <Button x:Name="CompactFullscreenButton"
                        Grid.Row="2"
                        Content="F"
                        ToolTip="Fullscreen"
                        Click="CompactFullscreenButton_Click"
                        Style="{StaticResource CompactIconButtonStyle}" />
                <TextBlock x:Name="CompactStatusTextBlock"
                           Text="Disconnected."
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <Grid x:Name="VideoStage"
              Grid.Column="1"
              Background="#000000"
              MouseLeftButtonDown="VideoStage_MouseLeftButtonDown">
            <Image x:Name="VideoImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Canvas x:Name="RemoteCursorLayer"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <Grid x:Name="RemoteCursor"
                      Width="22"
                      Height="28">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="RemoteCursorScale"
                                        ScaleX="0.45"
                                        ScaleY="0.45" />
                    </Grid.RenderTransform>
                    <Path Data="M 1 1 L 1 21 L 6.5 15.4 L 10.2 24.2 L 14.2 22.5 L 10.4 13.9 L 18.8 13.9 Z"
                          Fill="#FFFFFF"
                          Stroke="#000000"
                          StrokeThickness="1.5"
                          StrokeLineJoin="Round" />
                </Grid>
            </Canvas>

            <Grid x:Name="EmptyStatePanel"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="28"
                        Padding="12,8"
                        Background="#1AFFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="EmptyStateStatusDot"
                                 Width="8"
                                 Height="8"
                                 Fill="{StaticResource WarningBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="EmptyStateStatusTextBlock"
                                   Text="Waiting for iPhone or iPad..."
                                   Foreground="#D8D8DE"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="520"
                            Margin="32">
                    <Grid Width="138"
                          Height="96"
                          HorizontalAlignment="Center">
                        <Border CornerRadius="10"
                                Background="#17171C"
                                BorderBrush="#3A3A42"
                                BorderThickness="1" />
                        <Border Width="96"
                                Height="8"
                                CornerRadius="4"
                                Background="#3A3A42"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,-16"
                                HorizontalAlignment="Center" />
                        <TextBlock Text="iMirror"
                                   Foreground="#F5F5F7"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock x:Name="EmptyStateTextBlock"
                               Text="Ready to mirror"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#F5F5F7"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,34,0,0" />
                    <TextBlock x:Name="EmptyStateDetailTextBlock"
                               Text="Open Control Center, tap Screen Mirroring, then choose iMirror."
                               Foreground="#B9B9C0"
                               FontSize="15"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               Margin="0,12,0,0" />

                    <Grid Margin="0,32,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#141418"
                                BorderBrush="#2C2C31"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="1"
                                           Foreground="#60CDFF"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Open Control Center"
                                           Foreground="#F5F5F7"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="Swipe down from the top-right."
                                           Foreground="#8F8F98"
                                           FontSize="12"
                                           TextWrapping="Wrap"
