<ui:FluentWindow x:Class="MacMirrorReceiver.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="iMirror Settings"
                 AutomationProperties.Name="iMirror Settings"
                 Width="360"
                 MaxHeight="720"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="Transparent"
                 FontFamily="Segoe UI Variable Text, Segoe UI"
                 FontSize="13"
                 Foreground="{DynamicResource TextBrush}"
                 KeyDown="SettingsWindow_KeyDown"
                 Closing="SettingsWindow_Closing"
                 FocusManager.FocusedElement="{Binding ElementName=ReceiverNameTextBox}"
                 UseLayoutRounding="True"
                 SnapsToDevicePixels="True">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MacMirrorReceiver/SharedResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <ui:TitleBar Title="Settings"
                         ShowMinimize="False"
                         ShowMaximize="False"
                         ShowClose="False" />
            <ui:Button x:Name="SettingsCloseButton"
                       Width="32"
                       Height="32"
                       Padding="0"
                       Margin="0,0,10,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Content="&#x2715;"
                       ToolTip="Close"
                       AutomationProperties.Name="Close settings"
                       Appearance="Transparent"
                       Click="SettingsCloseButton_Click" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0"
                      Margin="18,8,18,0">
            <StackPanel>
                <ui:Card Padding="14"
                         Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="GENERAL"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Receiver name" Style="{StaticResource LabelTextStyle}" />
                        <ui:TextBox x:Name="ReceiverNameTextBox"
                                    AutomationProperties.Name="Receiver name"
                                    TextChanged="ReceiverNameTextBox_TextChanged"
                                    Height="40"
                                    Padding="12,0"
                                    VerticalContentAlignment="Center" />
                        <TextBlock Text="Name shown to nearby Apple devices. Requires restart."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Padding="14"
                         Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="VIDEO"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Quality mode" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock x:Name="RenderModeSettingDetailTextBlock"
                                   Text="1080p AirPlay display for smooth mirroring."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"
                                   LineHeight="18" />
                        <RadioButton x:Name="StableRenderModeRadioButton"
                                     GroupName="ReceiverRenderMode"
                                     AutomationProperties.Name="Stable quality mode"
                                     Checked="RenderModeSettingRadioButton_Checked"
                                     Margin="0,12,0,0">
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="Stable (recommended)" FontWeight="SemiBold" />
                                <TextBlock Text="1080p, smoother on more PCs."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="QualityRenderModeRadioButton"
                                     GroupName="ReceiverRenderMode"
                                     AutomationProperties.Name="High quality mode"
                                     Checked="RenderModeSettingRadioButton_Checked"
                                     Margin="0,10,0,0">
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="High quality" FontWeight="SemiBold" />
                                <TextBlock Text="Native GPU path. May not work on all hardware."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </RadioButton>
                        <TextBlock x:Name="RenderModeNoteTextBlock"
                                   Text="GPU mode is enabled when hardware decode is available."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,10,0,0"
                                   LineHeight="17" />
                        <TextBlock x:Name="RenderModeOverrideTextBlock"
                                   Text="IMIRROR_RENDER_MODE is overriding this setting."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,10,0,0"
                                   LineHeight="17" />

                        <TextBlock Text="Video engine" FontWeight="SemiBold" Margin="0,16,0,0" />
                        <RadioButton x:Name="AutoVideoEngineRadioButton"
                                     GroupName="VideoEngine"
                                     AutomationProperties.Name="Auto video engine"
                                     Checked="VideoEngineRadioButton_Checked"
                                     Margin="0,8,0,0">
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="Auto (GPU)" FontWeight="SemiBold" />
                                <TextBlock Text="Hardware decode when available, software fallback otherwise."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="SoftwareVideoEngineRadioButton"
                                     GroupName="VideoEngine"
                                     AutomationProperties.Name="Force software video engine"
                                     Checked="VideoEngineRadioButton_Checked"
                                     Margin="0,8,0,0">
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="Force software" FontWeight="SemiBold" />
                                <TextBlock Text="Always use the FFmpeg software decoder."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </RadioButton>
                        <TextBlock x:Name="VideoEngineOverrideTextBlock"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,8,0,0"
                                   LineHeight="17" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Padding="14"
                         Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="AUDIO"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,10" />
                        <ui:ToggleSwitch x:Name="AudioEnabledCheckBox"
                                         Content="Receive audio from senders"
                                         Checked="AudioEnabledCheckBox_Changed"
                                         Unchecked="AudioEnabledCheckBox_Changed" />
                        <TextBlock x:Name="AudioEnabledOverrideTextBlock"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,6,0,0"
                                   LineHeight="17" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Audio sync offset"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="AudioSyncOffsetValueText"
                                       Grid.Column="1"
                                       Text="120 ms"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Slider x:Name="AudioSyncOffsetSlider"
                                AutomationProperties.Name="Audio sync offset"
                                Minimum="60"
                                Maximum="220"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                ValueChanged="AudioSyncOffsetSlider_ValueChanged"
                                Margin="0,6,0,0" />
                        <TextBlock Text="Delays audio relative to video. Takes effect immediately."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                        <TextBlock x:Name="AudioSyncOffsetOverrideTextBlock"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,6,0,0"
                                   LineHeight="17" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Padding="14"
                         Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="Advanced"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,10" />
                        <Expander Header="Diagnostics"
                                  IsExpanded="False"
                                  Foreground="{StaticResource MutedTextBrush}">
                            <StackPanel Margin="0,8,0,0">
                                <Border Background="{StaticResource WarnBannerBackBrush}"
                                        BorderBrush="{StaticResource WarnBannerBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <TextBlock Text="Diagnostic files may contain screen content or session keys. Never share them."
                                               Foreground="{StaticResource WarnBannerTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               LineHeight="17" />
                                </Border>
                                <ui:ToggleSwitch x:Name="WriteDiagnosticsCheckBox"
                                                 Content="Write diagnostics"
                                                 Checked="DiagnosticsCheckBox_Changed"
                                                 Unchecked="DiagnosticsCheckBox_Changed"
                                                 Margin="0,10,0,0" />
                                <ui:ToggleSwitch x:Name="DumpH264CheckBox"
                                                 Content="Dump H.264"
                                                 Checked="DiagnosticsCheckBox_Changed"
                                                 Unchecked="DiagnosticsCheckBox_Changed"
                                                 Margin="0,8,0,0" />
                                <ui:ToggleSwitch x:Name="DumpAudioCheckBox"
                                                 Content="Dump audio"
                                                 Checked="DiagnosticsCheckBox_Changed"
                                                 Unchecked="DiagnosticsCheckBox_Changed"
                                                 Margin="0,8,0,0" />
                                <TextBlock x:Name="DiagnosticsOverrideTextBlock"
                                           Text="An IMIRROR_DUMP_* or IMIRROR_WRITE_DIAGNOSTICS variable is overriding one or more of these."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           Margin="0,8,0,0"
                                           LineHeight="17" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Margin="18,0,18,18">
            <Border x:Name="SettingsRestartPanel"
                    Background="{StaticResource WarnBannerBackBrush}"
                    BorderBrush="{StaticResource WarnBannerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Restart required to apply; active sessions will end."
                               Foreground="{StaticResource WarnBannerTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               LineHeight="17" />
                    <ui:Button x:Name="SettingsRestartButton"
                               Content="Restart now"
                               AutomationProperties.Name="Restart iMirror now"
                               Click="SettingsRestartButton_Click"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="VersionTextBlock"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           FontSize="12"
                           VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/Balragon/iMirror/releases"
                               RequestNavigate="UpdatesHyperlink_RequestNavigate">
                        Check for updates
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
