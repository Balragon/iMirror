<Window x:Class="MacMirrorReceiver.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iMirror Settings"
        AutomationProperties.Name="iMirror Settings"
        Width="360"
        MaxHeight="720"
        SizeToContent="Height"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        Foreground="#1D1D1F"
        KeyDown="SettingsWindow_KeyDown"
        Closing="SettingsWindow_Closing"
        FocusManager.FocusedElement="{Binding ElementName=ReceiverNameTextBox}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FBFBFD" />
        <SolidColorBrush x:Key="TextBrush" Color="#1D1D1F" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6E6E73" />
        <SolidColorBrush x:Key="LineBrush" Color="#D2D2D7" />
        <SolidColorBrush x:Key="FieldBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#007AFF" />

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="CompactIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="#E5E5EA"
            BorderThickness="1"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Settings"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button x:Name="SettingsCloseButton"
                        Grid.Column="1"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Content="&#x2715;"
                        ToolTip="Close"
                        AutomationProperties.Name="Close settings"
                        Click="SettingsCloseButton_Click"
                        Style="{StaticResource CompactIconButtonStyle}" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0">
                <StackPanel>
                    <TextBlock Text="GENERAL"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,8" />
                    <TextBlock Text="Receiver name" Style="{StaticResource LabelTextStyle}" />
                    <TextBox x:Name="ReceiverNameTextBox"
                             AutomationProperties.Name="Receiver name"
                             TextChanged="ReceiverNameTextBox_TextChanged"
                             Style="{StaticResource FieldTextBoxStyle}" />
                    <TextBlock Text="Shown to senders on the network. Restart required."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />

                    <TextBlock Text="VIDEO"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,18,0,8" />
                    <TextBlock Text="Quality mode" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock x:Name="RenderModeSettingDetailTextBlock"
                               Text="1080p AirPlay display for smooth mirroring."
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,5,0,0"
                               LineHeight="18" />
                    <RadioButton x:Name="StableRenderModeRadioButton"
                                 GroupName="ReceiverRenderMode"
                                 AutomationProperties.Name="Stable quality mode"
                                 Checked="RenderModeSettingRadioButton_Checked"
                                 Margin="0,12,0,0">
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="Stable (recommended)" FontWeight="SemiBold" />
                            <TextBlock Text="1080p, smoother on more PCs."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="QualityRenderModeRadioButton"
                                 GroupName="ReceiverRenderMode"
                                 AutomationProperties.Name="High quality mode"
                                 Checked="RenderModeSettingRadioButton_Checked"
                                 Margin="0,10,0,0">
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="High quality" FontWeight="SemiBold" />
                            <TextBlock Text="Experimental high-res testing only."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </RadioButton>
                    <TextBlock x:Name="RenderModeNoteTextBlock"
                               Text="GPU mode is enabled when hardware decode is available."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,10,0,0"
                               LineHeight="17" />
                    <TextBlock x:Name="RenderModeOverrideTextBlock"
                               Text="IMIRROR_RENDER_MODE is overriding this setting."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,10,0,0"
                               LineHeight="17" />

                    <TextBlock Text="Video engine" FontWeight="SemiBold" Margin="0,16,0,0" />
                    <RadioButton x:Name="AutoVideoEngineRadioButton"
                                 GroupName="VideoEngine"
                                 AutomationProperties.Name="Auto video engine"
                                 Checked="VideoEngineRadioButton_Checked"
                                 Margin="0,8,0,0">
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="Auto (GPU)" FontWeight="SemiBold" />
                            <TextBlock Text="Hardware decode when available, software fallback otherwise."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SoftwareVideoEngineRadioButton"
                                 GroupName="VideoEngine"
                                 AutomationProperties.Name="Force software video engine"
                                 Checked="VideoEngineRadioButton_Checked"
                                 Margin="0,8,0,0">
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="Force software" FontWeight="SemiBold" />
                            <TextBlock Text="Always use the FFmpeg software decoder."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </RadioButton>
                    <TextBlock x:Name="VideoEngineOverrideTextBlock"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,8,0,0"
                               LineHeight="17" />

                    <TextBlock Text="AUDIO"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,18,0,8" />
                    <CheckBox x:Name="AudioEnabledCheckBox"
                              Content="Receive audio from senders"
                              Checked="AudioEnabledCheckBox_Changed"
                              Unchecked="AudioEnabledCheckBox_Changed" />
                    <TextBlock x:Name="AudioEnabledOverrideTextBlock"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,6,0,0"
                               LineHeight="17" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Audio sync offset"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="AudioSyncOffsetValueText"
                                   Grid.Column="1"
                                   Text="120 ms"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <Slider x:Name="AudioSyncOffsetSlider"
                            AutomationProperties.Name="Audio sync offset"
                            Minimum="60"
                            Maximum="220"
                            TickFrequency="10"
                            IsSnapToTickEnabled="True"
                            ValueChanged="AudioSyncOffsetSlider_ValueChanged"
                            Margin="0,6,0,0" />
                    <TextBlock Text="Higher values delay audio to match video. Applies immediately."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <TextBlock x:Name="AudioSyncOffsetOverrideTextBlock"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,6,0,0"
                               LineHeight="17" />

                    <Expander Header="Advanced / diagnostics"
                              IsExpanded="False"
                              Margin="0,18,0,8"
                              Foreground="{StaticResource MutedTextBrush}">
                        <StackPanel Margin="0,8,0,0">
                            <Border Background="#FFF8E8"
                                    BorderBrush="#FFE0A8"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <TextBlock Text="These files can contain private screen content and key material. Keep them local."
                                           Foreground="#6B4A00"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           LineHeight="17" />
                            </Border>
                            <CheckBox x:Name="WriteDiagnosticsCheckBox"
                                      Content="Write diagnostics"
                                      Checked="DiagnosticsCheckBox_Changed"
                                      Unchecked="DiagnosticsCheckBox_Changed"
                                      Margin="0,10,0,0" />
                            <CheckBox x:Name="DumpH264CheckBox"
                                      Content="Dump H.264"
                                      Checked="DiagnosticsCheckBox_Changed"
                                      Unchecked="DiagnosticsCheckBox_Changed"
                                      Margin="0,8,0,0" />
                            <CheckBox x:Name="DumpAudioCheckBox"
                                      Content="Dump audio"
                                      Checked="DiagnosticsCheckBox_Changed"
                                      Unchecked="DiagnosticsCheckBox_Changed"
                                      Margin="0,8,0,0" />
                            <TextBlock x:Name="DiagnosticsOverrideTextBlock"
                                       Text="An IMIRROR_DUMP_* or IMIRROR_WRITE_DIAGNOSTICS variable is overriding one or more of these."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"
                                       Margin="0,8,0,0"
                                       LineHeight="17" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2">
                <Border x:Name="SettingsRestartPanel"
                        Background="#FFF8E8"
                        BorderBrush="#FFE0A8"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,12,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Restart required. AirPlay connections will disconnect."
                                   Foreground="#6B4A00"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   LineHeight="17" />
                        <Button x:Name="SettingsRestartButton"
                                Content="Restart now"
                                AutomationProperties.Name="Restart iMirror now"
                                Click="SettingsRestartButton_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VersionTextBlock"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               FontSize="12"
                               VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://github.com/Balragon/iMirror/releases"
                                   RequestNavigate="UpdatesHyperlink_RequestNavigate">
                            Check for updates
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
